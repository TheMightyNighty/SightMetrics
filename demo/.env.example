# SightMetrics Demo - Umgebungsvariablen
# -------------------------------------------------------
# Kopieren und anpassen:  cp demo/.env.example demo/.env
# demo/.env ist gitignoriert - NIEMALS echte Passwörter committen.
# -------------------------------------------------------

# MariaDB
MARIADB_ROOT_PASSWORD=root
MARIADB_T3_PASSWORD=t3

# Cube-DB: User-Passwörter (werden beim ersten 'docker compose up' angelegt)
# CUBE_RW_PASSWORD muss mit dem Passwort in CUBE_DSN übereinstimmen.
CUBE_RW_PASSWORD=cube_rw
CUBE_RO_PASSWORD=report_ro

# DuckDB-Verbindungs-DSN für die Ingestion (ingestion-Profil).
# Passwort muss CUBE_RW_PASSWORD entsprechen.
CUBE_DSN=host=db port=3306 user=cube_rw password=cube_rw database=analytics
