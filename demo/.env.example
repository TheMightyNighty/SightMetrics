# SightMetrics Demo – environment variables
# -------------------------------------------------------
# Copy and adjust:  cp demo/.env.example demo/.env
# demo/.env is gitignored – NEVER commit real passwords.
# -------------------------------------------------------

# MariaDB
MARIADB_ROOT_PASSWORD=root
MARIADB_T3_PASSWORD=t3

# Cube DB: user passwords (created on the first 'docker compose up')
# CUBE_RW_PASSWORD must match the password in CUBE_DSN.
CUBE_RW_PASSWORD=cube_rw
CUBE_RO_PASSWORD=report_ro

# DuckDB connection DSN for the ingestion (ingestion profile).
# Password must match CUBE_RW_PASSWORD.
CUBE_DSN=host=db port=3306 user=cube_rw password=cube_rw database=analytics
