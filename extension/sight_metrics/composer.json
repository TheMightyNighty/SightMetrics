{
    "name": "sightmetrics/sight-metrics",
    "type": "typo3-cms-extension",
    "description": "SightMetrics – privacy-friendly, log-file based web analytics as a TYPO3 backend module (read-only on the cube DB; requires the separately deployed SightMetrics ingestion pipeline)",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Robert Schleiermacher",
            "email": "robert.schleiermacher@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/TheMIghtyNighty/SightMetrics/issues",
        "source": "https://github.com/TheMIghtyNighty/SightMetrics",
        "docs": "https://docs.typo3.org/p/sightmetrics/sight-metrics/main/en-us/"
    },
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-backend": "^13.4 || ^14.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "typo3/coding-standards": "^0.8",
        "phpunit/phpunit": "^11.0",
        "typo3/testing-framework": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "SightMetrics\\": "Classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "sight_metrics"
        }
    }
}
